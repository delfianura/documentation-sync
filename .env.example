# rago-sync configuration — copy to .env and fill in your paths.
# All paths must be absolute or relative to the rago-sync repo root.

# Path to THIS repo (the rago-sync installation) — used by skills to locate the CLI
export RAGO_SYNC_DIR=/path/to/documentation-sync

# Path to your local gl-sdk checkout (contains gitbook/ and libs/)
export RAGO_SYNC_GL_SDK_REPO=/path/to/gl-sdk

# Path to your local gen-ai-sdk-cookbook checkout (contains gen-ai/)
export RAGO_SYNC_COOKBOOK_REPO=/path/to/gen-ai-sdk-cookbook

# Path to the GitBook docs directory inside gl-sdk (for generate_map.py)
export RAGO_SYNC_GITBOOK_DIR=/path/to/gl-sdk/gitbook/gen-ai-sdk

# Optional: GitBook branch to diff against (defaults to origin/docs/gitbook-sync)
# export RAGO_SYNC_GITBOOK_BRANCH=origin/docs/gitbook-sync

# Optional: email notification settings (for `detect --email`)
# export RAGO_SYNC_EMAIL_SMTP_HOST=smtp.gmail.com
# export RAGO_SYNC_EMAIL_SMTP_PORT=587
# export RAGO_SYNC_EMAIL_USER=your-email@gmail.com
# export RAGO_SYNC_EMAIL_PASSWORD=your-app-password
# export RAGO_SYNC_EMAIL_TO=recipient@example.com